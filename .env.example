# === Frontend (Vite) — variables de entorno ===
# Copia este archivo como .env y rellena con tus valores reales.
# En producción (Vercel) estas variables se configuran en el panel del proyecto.

# Openpay — se obtienen en https://dashboard.openpay.mx (sección Configuración > Llaves)
VITE_OPENPAY_MERCHANT_ID=tu_merchant_id
VITE_OPENPAY_PUBLIC_KEY=pk_tu_llave_publica

# Modo de cobro:
#   true  = ambiente de pruebas (sandbox, dinero simulado)  ← desarrollo
#   false = cobros reales (producción)                       ← al pasar a producción
# Si esta variable falta, el sistema se queda en pruebas por seguridad.
VITE_OPENPAY_SANDBOX=true
